{
  "Display": {
    "UpdatePeriod": 3,
    "DeviceRetrySeconds": 5,
    "Grid": {
      "Columns": 4,
      "Rows": 4
    },
    "Widgets": [
      {
        "Type": "CpuUsage",
        "Column": 0,
        "Row": 0,
        "RowSpan": 2
      },
      {
        "Type": "MemoryUsage",
        "Column": 1,
        "Row": 0,
        "RowSpan": 2
      },
      {
        "Type": "FileSystem",
        "Column": 2,
        "Row": 0,
        "RowSpan": 2
      },
      {
        "Type": "Network",
        "Column": 3,
        "Row": 0,
        "RowSpan": 2
      },
      {
        "Type": "LoadAverage",
        "Column": 0,
        "Row": 2
      },
      {
        "Type": "GpuUsage",
        "Column": 1,
        "Row": 2,
        "RowSpan": 2
      },
      {
        "Type": "DiskIo",
        "Column": 2,
        "Row": 2,
        "RowSpan": 2
      },
      {
        "Type": "Fan",
        "Column": 3,
        "Row": 2
      },
      {
        "Type": "CpuClock",
        "Column": 0,
        "Row": 3
      },
      {
        "Type": "Power",
        "Column": 3,
        "Row": 3
      }
    ]
  },

  "Serilog": {
    "Using": [
      "Serilog.Enrichers.Environment",
      "Serilog.Sinks.File"
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "log/mac-stat-display_.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} {Level:u4} {MachineName} [{ThreadId}] - {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
